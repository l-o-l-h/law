}
{\field {\*\fldinst HYPERLINK "https://www.westlaw.com/Link/Document/FullText?findType=Y&serNum=1964124194&pubNum=661&originatingDoc=Iddad075af77c11d98ac8f235252e36df&refType=RP&originationContext=document&vr=3.0&rs=cblt1.0&transitionType=DocumentItem&contextData=(sc.UserEnteredCitation)" }{\fldrslt 
